{
    "workbench.editorAssociations": {
        "scribbles.md": "default",
        "notes.md": "default",
        "*.md": "vscode.markdown.preview.editor"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "always",
        }
    },
    "files.associations": {
        "array": "cpp",
        "string_view": "cpp",
        "initializer_list": "cpp",
        "utility": "cpp"
    },
    "iis.configDir": ""
}